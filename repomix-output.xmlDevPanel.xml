local ReplicatedStorage = game:GetService("ReplicatedStorage")
local DevStates = require(script.Parent.DevStates)
local Iris = require(ReplicatedStorage.Packages.Iris)

local ControlPanel = {}

function ControlPanel:Render()
	Iris.Window({ "Control Panel" }, { isOpened = DevStates.ShowControllerPanel })
	do
		Iris.MenuBar()
		do
			Iris.Menu({ "Tools" })
			do
				Iris.MenuToggle({ "Output Console" }, { isChecked = DevStates.ShowOutputConsole })
			end
			Iris.End()
		end
		Iris.End()
	end
	Iris.End()
end

return ControlPanel
</file>

<file path="src/startup/ClientStartup/DevPanel/DevOutputConsole.luau">
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Iris = require(ReplicatedStorage.Packages.Iris)
local OrderedCollections = require(ReplicatedStorage.Packages.OrderedCollections)

local LogWindow = {}
local logs = OrderedCollections.Set.new()

-- * Types
export type MessageType = "Log" | "Info" | "Warning" | "Error" | "Success" | "Debug"
export type MessageContext = {
	message: string,
	messageType: MessageType,
}

-- * Constant
local MAX_LOGS = 30
local COLORS = {
	Log = Color3.fromRGB(255, 255, 255),
	Info = Color3.fromRGB(0, 255, 255),
	Warning = Color3.fromRGB(255, 255, 0),
	Error = Color3.fromRGB(255, 0, 0),
	Success = Color3.fromRGB(0, 255, 0),
	Debug = Color3.fromRGB(255, 0, 255),
}
local MESSAGE_FILTERS = { "All", "Log", "Info", "Warning", "Error", "Success", "Debug" }
local filterStates = {
	All = Iris.State(true),
	Log = Iris.State(true),
	Info = Iris.State(true),
	Warning = Iris.State(true),
	Error = Iris.State(true),
	Success = Iris.State(true),
	Debug = Iris.State(true),
}

-- * API
function LogWindow:SendMessage(message: string, messageType: MessageType?)
	if logs:Size() >= MAX_LOGS then
		logs:PopFront()
	end

	local context: MessageContext = {
		message = `[{os.date("%H:%M:%S")}]: {message}`,
		messageType = messageType or "Log",
	}
	print(context)

	logs:PushBack(context)
end

function LogWindow:Render()
	Iris.Window({ "Log Window" })
	do
		Iris.SeparatorText({ "Log Filters" })
		Iris.SameLine()
		do
			for _, fType in ipairs(MESSAGE_FILTERS) do
				Iris.Checkbox({ fType }, { isChecked = filterStates[fType] })
			end
		end
		Iris.End()
		Iris.Separator()

		Iris.SeparatorText({ "Output" })
		Iris.Indent()
		do
			logs:Each(function(context: MessageContext)
				if filterStates.All:get() == true or filterStates[context.messageType]:get() == true then
					Iris.TextColored({ context.message }, { color = COLORS[context.messageType] })
				end
			end)
		end
		Iris.End()
	end
	Iris.End()
end

return LogWindow
</file>

