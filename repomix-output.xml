<file path="src/core/Sound/SoundController/Channels/BaseSoundChannel.luau">
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local SoundService = game:GetService("SoundService")
local TweenService = game:GetService("TweenService")

local TweenUtils = require(ReplicatedStorage.Shared.Utils.TweenUtils)

local SoundChannel = {}
SoundChannel.__index = SoundChannel

type TweenInfoOption = TweenUtils.TweenInfoOption

export type SoundChannel = typeof(setmetatable(
	{} :: {
		group: SoundGroup,
		sounds: { [string]: Sound },
		volume: number,
	},
	SoundChannel
))

function SoundChannel.new(): SoundChannel
	local self = setmetatable({
		group = Instance.new("SoundGroup"),
		sounds = {},
		volume = 1,
	}, SoundChannel) :: SoundChannel

	self:Init()
	return self
end

function SoundChannel:Init()
	self.group.Name = "SoundChannelGroup"
	self.group.Parent = SoundService
	self.group.Volume = 1
end

function SoundChannel:FindSound(name: string): Sound?
	return self.sounds[name]
end

function SoundChannel:GetSound(name: string): Sound?
	local sound = self:FindSound(name)
	if not sound then
		warn(`Sound {name} not found in channel`)
	end
	return sound
end

function SoundChannel:RequireSound(name: string): Sound
	local sound = self:FindSound(name)
	if not sound then
		error(`Sound {name} not found in channel`)
	end
	return sound
end

function SoundChannel:AddSound(name: string, sound: Sound)
	if self.sounds[name] then
		warn(`Sound {name} already exists in channel, overwriting`)
	end

	self.sounds[name] = sound
	sound.Parent = self.group
	sound.SoundGroup = self.group
	sound:SetAttribute("BaseVolume", sound.Volume)
end

function SoundChannel:AddSounds(sounds: { [string]: Sound })
	for name, sound in pairs(sounds) do
		self:AddSound(name, sound)
	end
end

function SoundChannel:AddSoundFromContainer(parent: Instance, defineFilter: ((Sound) -> string?)?)
	for _, instance in ipairs(parent:GetDescendants()) do
		if instance:IsA("Sound") then
			local sound = instance :: Sound
			if defineFilter then
				local newName = defineFilter(sound)
				if newName then
					self:AddSound(newName, sound)
				end
			else
				self:AddSound(sound.Name, sound)
			end
		end
	end
end

function SoundChannel:SetSoundVolume(name: string, volume: number, info: TweenInfoOption?): Tween
	local sound = self:RequireSound(name)
	local tweenInfo = TweenUtils.createInfo(info)
	local tween = TweenService:Create(sound, tweenInfo, { Volume = volume })
	tween:Play()
	return tween
end

function SoundChannel:SetChannelVolume(volume: number, info: TweenInfoOption?): Tween
	self.volume = volume
	local tweenInfo = TweenUtils.createInfo(info)
	local tween = TweenService:Create(self.group, tweenInfo, { Volume = volume })
	tween:Play()
	return tween
end

function SoundChannel:SetOutputVolume(volume: number, info: TweenInfoOption?): Tween
	local tweenInfo = TweenUtils.createInfo(info)
	local tween = TweenService:Create(self.group, tweenInfo, { Volume = volume })
	tween:Play()
	return tween
end

function SoundChannel:Play(name: string): Sound
	local sound = self:RequireSound(name)
	sound:Play()
	return sound
end

function SoundChannel:Stop(name: string)
	local sound = self:RequireSound(name)
	sound:Stop()
end

function SoundChannel:StopAll()
	for _, sound in pairs(self.sounds) do
		sound:Stop()
	end
end

function SoundChannel:Pause(name: string)
	local sound = self:RequireSound(name)
	sound:Pause()
end

function SoundChannel:Resume(name: string)
	local sound = self:RequireSound(name)
	sound:Resume()
end

return SoundChannel
</file>

<file path="src/core/Sound/SoundController/Channels/MusicChannel.luau">
local TweenService = game:GetService("TweenService")
local BaseSoundChannel = require(script.Parent.BaseSoundChannel)
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenUtils = require(ReplicatedStorage.Shared.Utils.TweenUtils)

local MusicChannel = {}
MusicChannel.__index = MusicChannel

export type MusicChannel = typeof(setmetatable(
	{} :: {
		group: SoundGroup,
		sounds: { [string]: Sound },
		volume: number,
		currentName: string?,
		currentSound: Sound?,
	},
	MusicChannel
))

type TweenInfoOption = TweenUtils.TweenInfoOption

function MusicChannel.new(): MusicChannel
	local self = BaseSoundChannel.new()
	setmetatable(self, MusicChannel)

	self.currentName = nil
	self.currentSound = nil
	return self
end

function MusicChannel:GetCurrentName(): string?
	return self.currentName
end

function MusicChannel:GetCurrentSound(): Sound?
	return self.currentSound
end

function MusicChannel:Play(name: string): Sound
	local sound = self:RequireSound(name)

	if self.currentSound and self.currentSound ~= sound then
		self.currentSound:Stop()
	end

	self.currentName = name
	self.currentSound = sound
	sound:Play()
	return sound
end

function MusicChannel:StopCurrent()
	if self.currentSound then
		self.currentSound:Stop()
	end
	self.currentName = nil
	self.currentSound = nil
end

function MusicChannel:Crossfade(fromName: string?, toName: string, duration: number?, info: TweenInfoOption?): Sound
	local toSound = self:RequireSound(toName)
	local fromSound = fromName and self:GetSound(fromName) or self.currentSound

	local tweenInfo = TweenUtils.createInfo(info or {
		Time = duration or 1,
	})

	local baseVolume = toSound:GetAttribute("BaseVolume")
	local targetVolume = if typeof(baseVolume) == "number" then baseVolume else toSound.Volume

	if fromSound and fromSound ~= toSound then
		TweenService:Create(fromSound, tweenInfo, { Volume = 0 }):Play()
	end

	toSound.Volume = 0
	toSound:Play()

	TweenService:Create(toSound, tweenInfo, { Volume = targetVolume }):Play()

	self.currentName = toName
	self.currentSound = toSound

	return toSound
end

return MusicChannel
</file>

<file path="src/core/Sound/SoundController/Channels/SFXChannel.luau">
local SoundService = game:GetService("SoundService")
local BaseSoundChannel = require(script.Parent.BaseSoundChannel)

local SFXChannel = {}
SFXChannel.__index = SFXChannel

export type PlayOptions = {
	parent: Instance?,
	volume: number?,
	playbackSpeed: number?,
	loop: boolean?,
	rolloffMaxDistance: number?,
	rolloffMinDistance: number?,
}

export type SFXChannel = typeof(setmetatable(
	{} :: {
		group: SoundGroup,
		sounds: { [string]: Sound },
		volume: number,
		activeSounds: { Sound },
	},
	SFXChannel
))

function SFXChannel.new(): SFXChannel
	local self = BaseSoundChannel.new()
	setmetatable(self, SFXChannel)
	self.activeSounds = {}
	return self
end

function SFXChannel:_track(sound: Sound)
	table.insert(self.activeSounds, sound)

	sound.Ended:Connect(function()
		for i, item in ipairs(self.activeSounds) do
			if item == sound then
				table.remove(self.activeSounds, i)
				break
			end
		end
	end)
end

function SFXChannel:Play(name: string, _options: PlayOptions?): Sound
	local options = _options or {}

	local template = self:RequireSound(name)
	local sound = template:Clone()

	sound.SoundGroup = self.group
	sound.Parent = options.parent or self.group

	if options.volume ~= nil then
		sound.Volume = options.volume
	end
	if options.playbackSpeed ~= nil then
		sound.PlaybackSpeed = options.playbackSpeed
	end
	if options.loop ~= nil then
		sound.Looped = options.loop
	end
	if options.rolloffMaxDistance ~= nil then
		sound.RollOffMaxDistance = options.rolloffMaxDistance
	end
	if options.rolloffMinDistance ~= nil then
		sound.RollOffMinDistance = options.rolloffMinDistance
	end

	sound:Play()
	self:_track(sound)

	if not sound.Looped then
		sound.Ended:Connect(function()
			if sound.Parent then
				sound:Destroy()
			end
		end)
	end

	return sound
end

function SFXChannel:PlayAtPosition(name: string, position: Vector3, _options: PlayOptions?): Sound
	local options = _options or {}

	local holder = Instance.new("Part")
	holder.Name = "SFXEmitter"
	holder.Anchored = true
	holder.CanCollide = false
	holder.CanTouch = false
	holder.CanQuery = false
	holder.Transparency = 1
	holder.Size = Vector3.new(0.2, 0.2, 0.2)
	holder.CFrame = CFrame.new(position)
	holder.Parent = SoundService

	options.parent = holder
	local sound = self:Play(name, options)

	sound.Ended:Connect(function()
		if holder.Parent then
			holder:Destroy()
		end
	end)

	return sound
end

function SFXChannel:AttachToPart(name: string, part: BasePart, _options: PlayOptions?): Sound
	local options = _options or {}
	options.parent = part
	return self:Play(name, options)
end

function SFXChannel:StopAll()
	for _, sound in ipairs(self.activeSounds) do
		if sound.Parent then
			sound:Stop()
			sound:Destroy()
		end
	end
	table.clear(self.activeSounds)
end

return SFXChannel
</file>

<file path="src/core/Sound/SoundController/init.luau">
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenUtils = require(ReplicatedStorage.Shared.Utils.TweenUtils)

local MusicChannel = require(script.Channels.MusicChannel)
local SFXChannel = require(script.Channels.SFXChannel)

local SoundController = {}
SoundController.__index = SoundController

type TweenInfoOption = TweenUtils.TweenInfoOption
export type ChannelName = "Music" | "SFX"

export type SoundController = typeof(setmetatable(
	{} :: {
		masterVolume: number,
		channels: {
			Music: MusicChannel.MusicChannel,
			SFX: SFXChannel.SFXChannel,
		},
	},
	SoundController
))

function SoundController.new(): SoundController
	local self = setmetatable({
		masterVolume = 1,
		channels = {
			Music = MusicChannel.new(),
			SFX = SFXChannel.new(),
		},
	}, SoundController)

	return self
end

function SoundController:_refreshVolumes(info: TweenInfoOption?)
	self.channels.Music:SetOutputVolume(self.channels.Music.volume * self.masterVolume, info)
	self.channels.SFX:SetOutputVolume(self.channels.SFX.volume * self.masterVolume, info)
end

function SoundController:SetMasterVolume(volume: number, info: TweenInfoOption?)
	self.masterVolume = volume
	self:_refreshVolumes(info)
end

function SoundController:SetVolume(volume: number, info: TweenInfoOption?)
	self:SetMasterVolume(volume, info)
end

function SoundController:SetChannelVolume(channelName: ChannelName, volume: number, info: TweenInfoOption?)
	local channel = self.channels[channelName]
	channel:SetChannelVolume(volume, info)
	channel:SetOutputVolume(channel.volume * self.masterVolume, info)
end

function SoundController:Play(channelName: ChannelName, soundName: string, options)
	local channel = self.channels[channelName]
	return channel:Play(soundName, options)
end

function SoundController:Stop(channelName: ChannelName, soundName: string)
	local channel = self.channels[channelName]
	channel:Stop(soundName)
end

function SoundController:PlayMusic(trackName: string)
	return self.channels.Music:Play(trackName)
end

function SoundController:CrossfadeMusic(fromName: string?, toName: string, duration: number?)
	return self.channels.Music:Crossfade(fromName, toName, duration)
end

function SoundController:StopMusic(trackName: string?)
	if trackName then
		self.channels.Music:Stop(trackName)
	else
		self.channels.Music:StopCurrent()
	end
end

function SoundController:PlaySFX(soundName: string, options)
	return self.channels.SFX:Play(soundName, options)
end

return SoundController.new()
</file>

