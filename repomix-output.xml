<file path="src/services/CameraService/CameraSystem/init.luau">
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local CameraContext = require(ReplicatedStorage.Shared.Core.CineCam.Context.CameraContext)
local CameraBrain = require(ReplicatedStorage.Shared.Core.CineCam.Core.CameraBrain)
local OrbitVCam = require(ReplicatedStorage.Shared.Core.CineCam.VirtualCameras.OrbitVCam)
local CameraSystem = {}
CameraSystem.__index = CameraSystem

local MAX_DELTA_TIME = 1 / 30 -- 30 hz
local RENDER_NAME = "CameraSystemRender"
local RENDER_PRIORITY = Enum.RenderPriority.Camera.Value

function CameraSystem.new()
	local context = CameraContext.new()
	local self = setmetatable({
		vcams = {
			Orbit = OrbitVCam.new(),
		},
		brain = CameraBrain.new(),
		context = context,
	}, CameraSystem)

	return self
end

function CameraSystem:Update(dt: number)
	dt = math.min(dt, MAX_DELTA_TIME)
	self.context.DeltaTime = dt
	self.brain:Update(self.context)
end

function CameraSystem:Init()
	self.brain:SetActiveVCam(self.vcams.Orbit)
	self:Start()
end

function CameraSystem:GetContext()
	return self.context
end

function CameraSystem:Start()
	if self.running then
		return
	end

	self.running = true

	RunService:BindToRenderStep(RENDER_NAME, RENDER_PRIORITY, function(delta: number)
		self:Update(delta)
	end)
end

function CameraSystem:Stop()
	if not self.running then
		return
	end
	self.running = false

	RunService:UnbindFromRenderStep(RENDER_NAME)
end

return CameraSystem.new()
</file>

<file path="src/core/CineCam/VirtualCameras/OrbitVCam.luau">
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local InputService = require(ReplicatedStorage.Shared.Core.InputService)
local CameraContext = require(script.Parent.Parent.Context.CameraContext)
local CameraLookAtModule = require(script.Parent.Parent.Pipe.Modules.Aim.CameraLookAtModule)
local CameraOffsetModule = require(script.Parent.Parent.Pipe.Modules.Noise.CameraOffsetModule)
local CameraOrbitModule = require(script.Parent.Parent.Pipe.Modules.Body.CameraOrbitModule)
local BaseVirtualCamera = require(script.Parent.Parent.VirtualCameras.BaseVCam)
local CameraTargetObjectModule = require(script.Parent.Parent.Pipe.Modules.Extensions.CameraTargetObjectModule)

-- * Orbit
local OrbitVCam = {}
OrbitVCam.__index = OrbitVCam

-- * Types
type CameraContext = CameraContext.CameraContext

-- * Constructor
function OrbitVCam.new()
	local orbitModule = CameraOrbitModule.new()
	local lookAtModule = CameraLookAtModule.new()
	local offsetModule = CameraOffsetModule.new()
	local objectTargetModule = CameraTargetObjectModule.new()

	orbitModule.Yaw.SmoothFactor = 4
	orbitModule.Pitch.SmoothFactor = 5
	orbitModule.Distance.SmoothFactor = 6

	local self = setmetatable(
		BaseVirtualCamera.new({
			objectTargetModule,
			orbitModule,
			lookAtModule,
			offsetModule,
		}),
		OrbitVCam
	)

	self.direction = Vector2.zero
	self.zoomDis = 0

	local mapper = InputService:GetActionMapper()
	local mouseDevice = InputService:GetMouseDevice()

	local look: InputAction = mapper:GetAction("Gameplay", "Look")
	local lookDelta: InputAction = mapper:GetAction("Gameplay", "LookDelta")
	local zoomDis: InputAction = mapper:GetAction("Gameplay", "ZoomDistance")
	local zoomDisDelta: InputAction = mapper:GetAction("Gameplay", "ZoomDistanceDelta")

	lookDelta.StateChanged:Connect(function(delta: Vector2)
		orbitModule.Yaw:AdjustTarget(delta.X)
		orbitModule.Pitch:AdjustTarget(delta.Y)
	end)

	zoomDisDelta.StateChanged:Connect(function(distance: number)
		orbitModule.Distance:AdjustTarget(-distance)
	end)

	look.StateChanged:Connect(function(direction: Vector2)
		self.direction = direction * Vector2.new(1, -1)
	end)

	zoomDis.StateChanged:Connect(function(distance: number)
		self.zoomDis = distance
	end)

	function self:_onUpdate()
		if mouseDevice:IsButtonDown(Enum.UserInputType.MouseButton2) then
			local delta = -mouseDevice:GetMoveDelta()
			orbitModule.Yaw:AdjustTarget(delta.X)
			orbitModule.Pitch:AdjustTarget(delta.Y)
		end

		orbitModule.Yaw:AdjustTarget(self.direction.X)
		orbitModule.Pitch:AdjustTarget(self.direction.Y)
		orbitModule.Distance:AdjustTarget(-self.zoomDis)
	end

	function self:GetObjectTargetModule()
		return objectTargetModule
	end

	function self:GetOrbitModule()
		return orbitModule
	end

	return self
end

-- * Methods
function OrbitVCam:Update(context: CameraContext, output)
	self:_onUpdate()

	-- ouput
	local result = BaseVirtualCamera.Update(self, context)
	output.Cframe = result.Body * result.Aim * result.Noise
	output.Fov = result.Fov
end

return OrbitVCam
</file>

<file path="src/services/CameraService/Client.luau">
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local CameraSystem = require(script.Parent.CameraSystem)
local Promise = require(ReplicatedStorage.Packages.Promise)
local Knit = require(ReplicatedStorage.Packages.Knit)
local HoenKnit = require(ReplicatedStorage.Shared.Core.HoenKnit)

local CameraController = HoenKnit.CreateController({
	Name = "CameraController",
	_currentTransitionPromise = nil,
})
local Logger = CameraController._logger
Logger:SetDefaultCategory("Gameplay")

-- * Private
function CameraController:_cancelCurrent()
	if self._currentTransitionPromise then
		self._currentTransitionPromise:cancel()
		self._currentTransitionPromise = nil
	end
end

function CameraController:_playTransition()
	return Promise.new(function(resolve, reject, onCancel)
		local cancelled = false

		onCancel(function()
			cancelled = true
			reject("Cancelled")
		end)

		-- TODO: fade out, blur, etc.
		task.spawn(function()
			if cancelled then
				return
			end

			self:MoveCameraToCurrentMap()

			resolve()
		end)
	end)
end

-- * Public
function CameraController:MoveCameraTo(cameraPivot: BasePart)
	print("Moving camera to", cameraPivot.Name)
	CameraSystem:GetContext().CameraState.LookAtObject = cameraPivot
end

function CameraController:MoveCameraToCurrentMap()
	local MapController = Knit.GetController("MapController")
	local map = MapController:GetCurrentMap()
	if not map then
		return
	end

	self:MoveCameraTo(map.CameraPivot)
end

-- * Knit
function CameraController:KnitStart()
	local MapController = Knit.GetController("MapController")

	CameraSystem:Init()
	self:MoveCameraToCurrentMap()
	MapController.MapUpdated:Connect(function(mapName: string, transitionId: number)
		Logger:Info(`Camera updating to map {mapName}`)

		self:_cancelCurrent()

		local promise = self:_playTransition()
		self._currentTransitionPromise = promise

		promise
			:andThen(function()
				if self._currentTransitionPromise ~= promise then
					return
				end

				MapController.TransitionReady:Fire(transitionId)
			end)
			:catch(function(err)
				if err ~= "Cancelled" then
					Logger:Error("Error while playing transition: " .. err)
					MapController.TransitionReady:Fire(transitionId)
				end
			end)
			:finally(function()
				if self._currentTransitionPromise == promise then
					self._currentTransitionPromise = nil
				end
			end)
	end)
end

return CameraController
</file>

