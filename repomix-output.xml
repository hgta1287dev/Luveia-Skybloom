<file path="src/core/CineCam/Pipe/Modules/Extensions/CameraTargetObjectModule.luau">
local TargetModule = {}
TargetModule.__index = TargetModule

local function posObjOr(obj: BasePart?, default: Vector3)
	if obj and obj:IsA("BasePart") then
		return obj.Position
	end
	return default
end

function TargetModule.new(trackingObj: BasePart?, lookAtObj: BasePart?, overwrite: boolean?)
	local self = setmetatable({}, TargetModule)
	self.TrackingObject = trackingObj
	self.LookAtObject = lookAtObj
	self.Overwrite = overwrite or false
	return self
end

-- setting target runtime
function TargetModule:SetTargets(trackingObj: BasePart?, lookAtObj: BasePart?, overwrite: boolean?)
	self.TrackingObject = trackingObj
	self.LookAtObject = lookAtObj
	if overwrite ~= nil then
		self.Overwrite = overwrite
	end
end

-- update camera state
function TargetModule:Update(context, result)
	local cameraState = context.CameraState

	if self.Overwrite or cameraState.TrackingObject == nil then
		cameraState.TrackingObject = self.TrackingObject
	end

	if self.Overwrite or cameraState.LookAtObject == nil then
		cameraState.LookAtObject = self.LookAtObject
	end

	cameraState.TrackingTarget = posObjOr(cameraState.TrackingObject, cameraState.TrackingTarget)
	cameraState.LookAtTarget = posObjOr(cameraState.LookAtObject, cameraState.LookAtTarget)
end

return TargetModule
</file>

