<file path="src/services/CameraService/CameraSystem/CineCam/Input/CameraKeyboardInput.luau">
local UserInputService = game:GetService("UserInputService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local OrderedCollections = require(ReplicatedStorage.Packages.OrderedCollections)

local KeyboardInput = {}
KeyboardInput.__index = KeyboardInput

export type KeyboardState = {
	KeysDown: typeof(OrderedCollections.Set.new()),
	KeysPressed: typeof(OrderedCollections.Set.new()),
	KeysReleased: typeof(OrderedCollections.Set.new()),
}

export type KeyboardInput = typeof(setmetatable(
	{} :: {
		KeyboardState: KeyboardState,
	},
	KeyboardInput
))

function KeyboardInput.new(keyState: KeyboardState): KeyboardInput
	local self = setmetatable({
		KeyboardState = keyState,
	}, KeyboardInput)

	self:Init()
	return self
end

function KeyboardInput:Init()
	UserInputService.InputBegan:Connect(function(inputObject, gameProcessedEvent)
		if gameProcessedEvent then
			return
		end

		if inputObject.UserInputType ~= Enum.UserInputType.Keyboard then
			return
		end

		local keyCode = inputObject.KeyCode
		if keyCode == Enum.KeyCode.Unknown then
			return
		end

		if not self.KeyboardState.KeysDown:Has(keyCode) then
			self.KeyboardState.KeysDown:PushBack(keyCode)
			self.KeyboardState.KeysPressed:PushBack(keyCode)
		end
	end)

	UserInputService.InputEnded:Connect(function(inputObject, _gameProcessedEvent)
		if inputObject.UserInputType ~= Enum.UserInputType.Keyboard then
			return
		end

		local keyCode = inputObject.KeyCode
		if keyCode == Enum.KeyCode.Unknown then
			return
		end

		if not self.KeyboardState.KeysReleased:Has(keyCode) then
			self.KeyboardState.KeysReleased:PushBack(keyCode)
		end

		if self.KeyboardState.KeysDown:Has(keyCode) then
			self.KeyboardState.KeysDown:Pop(keyCode)
		end
	end)
end

function KeyboardInput:Flush()
	local state: KeyboardState = self.KeyboardState
	state.KeysPressed:Clear()
	state.KeysReleased:Clear()
end

return KeyboardInput
</file>

<file path="src/services/CameraService/CameraSystem/CineCam/Input/CameraMouseInput.luau">
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")
local OrderedCollections = require(ReplicatedStorage.Packages.OrderedCollections)

local MouseInput = {}
MouseInput.__index = MouseInput

type Set = typeof(OrderedCollections.Set.new())
export type MouseState = {
	MoveDelta: Vector2,
	ScrollDelta: number,
	ButtonsDown: Set,
	ButtonsPressed: Set,
	ButtonsReleased: Set,
}
export type MouseInput = typeof(setmetatable(
	{} :: {
		MouseState: MouseState,
	},
	MouseInput
))

function isMouseButtonType(input: Enum.UserInputType): boolean
	return input == Enum.UserInputType.MouseButton1
		or input == Enum.UserInputType.MouseButton2
		or input == Enum.UserInputType.MouseButton3
end

function MouseInput.new(mouseState: MouseState): MouseInput
	local self = setmetatable({
		MouseState = mouseState,
		LastLocation = UserInputService:GetMouseLocation(),
	}, MouseInput)

	self:Init()
	return self
end

function MouseInput:Init()
	local state: MouseState = self.MouseState

	do -- * Scroll and Movement
		UserInputService.InputChanged:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseWheel then
				state.ScrollDelta += input.Position.Z * -1
			elseif input.UserInputType == Enum.UserInputType.MouseMovement then
				state.MoveDelta = state.MoveDelta + (UserInputService:GetMouseLocation() - self.LastLocation)
				self.LastLocation = UserInputService:GetMouseLocation()
			end
		end)
	end

	do -- * Buttons
		UserInputService.InputBegan:Connect(function(input: InputObject, gpc: boolean)
			if gpc then
				return
			end

			local inputType = input.UserInputType
			if isMouseButtonType(inputType) then
				if not state.ButtonsDown:Has(inputType) then
					state.ButtonsDown:PushBack(inputType)
					state.ButtonsPressed:PushBack(inputType)
				end
			end
		end)

		UserInputService.InputEnded:Connect(function(input: InputObject, gpc: boolean)
			if gpc then
				return
			end

			local inputType = input.UserInputType
			if isMouseButtonType(inputType) then
				if not state.ButtonsReleased:Has(inputType) then
					state.ButtonsReleased:PushBack(inputType)
				end

				if state.ButtonsDown:Has(inputType) then
					state.ButtonsDown:Pop(inputType)
				end
			end
		end)
	end
end

function MouseInput:Flush()
	local state = self.MouseState
	state.MoveDelta = Vector2.zero
	state.ScrollDelta = 0
	state.ButtonsPressed:Clear()
	state.ButtonsReleased:Clear()
end

return MouseInput
</file>

<file path="src/services/CameraService/CameraSystem/CineCam/Input/CameraTouchInput.luau">
local UserInputService = game:GetService("UserInputService")

local TouchInput = {}
TouchInput.__index = TouchInput

export type TouchState = {
	Delta: Vector2,
	Pinch: number,
}
export type TouchInput = typeof(setmetatable(
	{} :: {
		TouchState: TouchState,
	},
	TouchInput
))

function TouchInput.new(touchState: TouchState): TouchInput
	local self = setmetatable({
		TouchState = touchState,
	}, TouchInput)

	return self
end

function TouchInput:Init()
	local state: TouchState = self.TouchState
	local lastPos = nil
	UserInputService.TouchMoved:Connect(function(touch)
		if lastPos then
			local delta = touch.Position - lastPos
			state.Delta.X = delta.X
			state.Delta.Y = delta.Y
		end
		lastPos = touch.Position
	end)

	UserInputService.TouchPinch:Connect(function(pinches)
		state.Pinch = pinches.Position.Z
	end)
end

return TouchInput
</file>

