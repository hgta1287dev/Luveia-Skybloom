<file path="src/core/Sound/SongSystem/init.luau">
local SoundController = require(script.Parent.SoundController)

local SongSystem = {}
SongSystem.__index = SongSystem

function SongSystem.new()
	local self = setmetatable({}, SongSystem)

	self.sound = SoundController
	self.current = nil
	self.next = nil

	return self
end

function SongSystem:Play(trackName)
	if self.current then
		self.sound.channels.Music:SetVolume(trackName, 0)
	end

	self.sound:Play("Music", trackName)
	self.current = trackName
end

return SongSystem.new()
</file>

<file path="src/core/Sound/SoundController/Channels/BaseSoundChannel.luau">
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local SoundService = game:GetService("SoundService")
local TweenService = game:GetService("TweenService")
local TweenUtils = require(ReplicatedStorage.Shared.Utils.TweenUtils)
local SoundChannel = {}
SoundChannel.__index = SoundChannel

-- * Types
type TweenInfoOption = TweenUtils.TweenInfoOption
export type SoundChannel = typeof(setmetatable(
	{} :: {
		group: SoundGroup,
		sounds: { [string]: Sound },
	},
	SoundChannel
))

-- * Constructor
function SoundChannel.new()
	local self = setmetatable({
		group = Instance.new("SoundGroup"),
		sounds = {},
	}, SoundChannel)

	self:Init()

	return self
end

function SoundChannel:Init()
	self.group.Parent = SoundService
end

-- * Getters
function SoundChannel:FindSound(name: string): Sound?
	return self.sounds[name]
end

function SoundChannel:GetSound(name: string): Sound?
	local sound = self:FindSound(name)
	if not sound then
		warn(`Sound {name} not found in channel`)
	end
	return sound
end

function SoundChannel:RequireSound(name: string): Sound
	local sound = self:FindSound(name)
	if not sound then
		error(`Sound {name} not found in channel`)
	end
	return sound
end

-- * Setters
function SoundChannel:AddSound(name: string, sound: Sound)
	if self.sounds[name] then
		warn(`Sound {name} already exists in channel, overwriting`)
	end
	self.sounds[name] = sound
	sound.Parent = self.group
	sound.SoundGroup = self.group
end

function SoundChannel:AddSounds(sounds: { [string]: Sound })
	for name, sound in pairs(sounds) do
		self:AddSound(name, sound)
	end
end

function SoundChannel:AddSoundFromContainer(parent: Instance, defineFilter: (Instance) -> string?)
	for _, sound: Sound in pairs(parent:QueryDescendants("Sound")) do
		if defineFilter then
			local newName = defineFilter(sound)
			if newName then
				self:AddSound(newName or sound.Name, sound)
			end
		else
			self:AddSound(sound.Name, sound)
		end
	end
end

-- * Settings
function SoundChannel:SetSoundVolume(name: string, volume: number, info: TweenInfoOption?): Tween
	local sound = self:RequireSound(name)
	local tweenInfo = TweenUtils.createInfo(info)
	local tween = TweenService:Create(sound, tweenInfo, { Volume = volume })
	tween:Play()
	return tween
end

function SoundChannel:SetChannelVolume(volume: number, info: TweenInfoOption?)
	local tweenInfo = TweenUtils.createInfo(info)
	local tween = TweenService:Create(self.group, tweenInfo, {
		Volume = volume,
	})
	tween:Play()
	return tween
end

-- * Main
function SoundChannel:Play(name: string)
	local sound = self:RequireSound(name)
	sound:Play()
end

function SoundChannel:Stop(name: string)
	local sound = self:RequireSound(name)
	sound:Stop()
end

function SoundChannel:StopAll()
	for _, sound in pairs(self.sounds) do
		sound:Stop()
	end
end

function SoundChannel:Pause(name: string)
	local sound = self:RequireSound(name)
	sound:Pause()
end

function SoundChannel:Resume(name: string)
	local sound = self:RequireSound(name)
	sound:Resume()
end

return SoundChannel
