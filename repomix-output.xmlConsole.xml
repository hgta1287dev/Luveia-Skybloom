local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local Signal = require(ReplicatedStorage.Packages.Signal)
local Logger = require(script.Logger)
local LoggerTypes = require(script.LoggerTypes)

local LoggerManager = {}
LoggerManager.__index = LoggerManager

-- * Types
type Signal = typeof(Signal.new())

export type LogLevel = LoggerTypes.LogLevel
export type Logger = Logger.Logger

export type LoggerManagerData = {
	_started: boolean,
	_enabled: boolean,
	_loggers: { [string]: Logger },

	MessageOut: Signal,
}
export type LoggerManager = typeof(setmetatable({} :: LoggerManagerData, LoggerManager))

-- * Constructor
function LoggerManager.new(): LoggerManager
	local self = setmetatable(
		{
			_started = false,
			_enabled = false,
			_loggers = {},

			MessageOut = Signal.new(),
		} :: LoggerManagerData,
		LoggerManager
	)

	return self
end

-- * Private
function LoggerManager:_dispatch(level: LogLevel, message: string)
	self:Log(level, message)
end

-- * Public
-- State management
function LoggerManager:Toggle(state: boolean)
	self._enabled = state
end

function LoggerManager:Enable()
	self:Toggle(true)
end

function LoggerManager:Disable()
	self:Toggle(false)
end

-- Log
function LoggerManager:Log(level: LogLevel, message: string)
	if not self._enabled then
		return
	end

	if level == "Error" or level == "Warning" then
		warn(message)
	else
		print(message)
	end

	if RunService:IsServer() then
	end

	self.MessageOut:Fire(message, level) --! message before level is to keep the order consistent
end

-- Lifecycle
function LoggerManager:Init()
	-- Check if already started
	if self._started then
		return
	end
	self._started = true

	-- Initializing
	self:Enable()
end

-- Logger Factory
function LoggerManager:CreateLogger(scope: string?, key: string?): Logger
	if scope and self._loggers[scope] then
		return self._loggers[scope]
	elseif key and self._loggers[key] then
		return self._loggers[key]
	end

	local logger = Logger.new(function(level, message)
		self:_dispatch(level, message)
	end, scope)

	if scope then
		self._loggers[scope] = logger
	elseif key then
		self._loggers[key] = logger
	end

	return logger
end

return LoggerManager.new()
</file>

<file path="src/core/LoggerManager/Logger.luau">
local RunService = game:GetService("RunService")
local LoggerTypes = require(script.Parent.LoggerTypes)
local Logger = {}
Logger.__index = Logger

--* Types
export type LogSide = LoggerTypes.LogSide
export type LogLevel = LoggerTypes.LogLevel
export type LogDispatchFn = (level: LogLevel, message: string) -> ()
export type LoggerData = {
	_scope: string?,
	_dispatch: LogDispatchFn,
	_side: LogSide,
}
export type Logger = typeof(setmetatable({} :: LoggerData, Logger))

-- * Helpers
local function getSidePrefix(): string
	local side = RunService:IsServer() and LoggerTypes.Sides.Server or LoggerTypes.Sides.Client
	return string.upper(side)
end

--* Constructor
function Logger.new(dispatchFn: LogDispatchFn, scope: string?): Logger
	return setmetatable({
		_dispatch = dispatchFn,
		_side = getSidePrefix(),
		_scope = scope,
	}, Logger)
end

function Logger:Destroy()
	self._manager._loggers[self._scope] = nil
	self._manager = nil
	table.clear(self)
	setmetatable(self, nil)
end

--* Private
function Logger:_format(...)
	local header

	if self._scope and self._scope ~= "" then
		header = string.format("[%s][%s]: ", self._side, self._scope)
	else
		header = string.format("[%s]: ", self._side)
	end

	local parts = table.pack(...)
	for i = 1, parts.n do
		parts[i] = tostring(parts[i])
	end

	return header .. table.concat(parts, " ")
end

function Logger:_log(level: LogLevel, ...)
	local message = self:_format(...)
	self._dispatch(level, message)
	return message
end

--* Public
-- Format
function Logger:Format(...)
	return self:_format(...)
end

-- Log
function Logger:Log(...)
	return self:_log(LoggerTypes.Levels.Log, ...)
end

function Logger:Info(...)
	return self:_log(LoggerTypes.Levels.Info, ...)
end

function Logger:Warn(...)
	return self:_log(LoggerTypes.Levels.Warn, ...)
end

function Logger:Success(...)
	return self:_log(LoggerTypes.Levels.Success, ...)
end

function Logger:Error(...)
	return self:_log(LoggerTypes.Levels.Error, ...)
end

function Logger:Debug(...)
	return self:_log(LoggerTypes.Levels.Debug, ...)
end

return Logger
</file>

