<file path="src/startup/ClientStartup/DevPanel/DevOutputConsole.luau">
local LocalizationService = game:GetService("LocalizationService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Janitor = require(ReplicatedStorage.Packages.Janitor)
local TableUtil = require(ReplicatedStorage.Packages.TableUtil)
local DevStates = require(script.Parent.DevStates)
local Iris = require(ReplicatedStorage.Packages._Index["sirmallard_iris@2.5.0"].iris)
local IrisTypes = require(ReplicatedStorage.Packages._Index["sirmallard_iris@2.5.0"].iris.Types)
local OrderedCollections =
	require(ReplicatedStorage.Packages._Index["hgta1287dev_ordered-collections@1.0.0"]["ordered-collections"])
local LoggerManager = require(ReplicatedStorage.Shared.Core.LoggerManager)

local OutputConsole = {}
OutputConsole.__index = OutputConsole

-- * Types
type Set<T> = OrderedCollections.Set<T>
type State<T> = IrisTypes.State<T>

export type MessageType = "Log" | "Info" | "Warning" | "Error" | "Success" | "Debug"
export type MessageContext = {
	message: string,
	messageType: MessageType,
	date: typeof(DateTime.now()),
}

-- export type OutputConsoleProps = {
-- 	maxLog: number?,
-- 	maxOutput: number?,
-- 	colors: { [MessageType]: Color3 }?,
-- }
export type OutputConsoleData = {
	maxLog: number,
	maxOutput: number,
	colors: { [MessageType]: Color3 },

	_messageBuffer: Set<MessageContext>,
	_filterStates: { [MessageType]: State<boolean> },
	_filterAllState: State<boolean>,
	_fullFilterState: State<boolean>,

	_showDate: State<boolean>,

	_janitor: typeof(Janitor.new()),
}
export type OutputConsole = typeof(setmetatable({} :: OutputConsoleData, OutputConsole))

-- * Default Config
local MAX_LOGS = 100000
local MAX_OUTPUT = 200
local COLORS = {
	Log = Color3.fromRGB(255, 255, 255),
	Info = Color3.fromRGB(0, 255, 255),
	Warning = Color3.fromRGB(255, 255, 0),
	Error = Color3.fromRGB(255, 0, 0),
	Success = Color3.fromRGB(0, 255, 0),
	Debug = Color3.fromRGB(255, 0, 255),
}
-- * Constants
local messageTypes: { MessageType } = { "Log", "Info", "Warning", "Error", "Success", "Debug" }
local filterTypes: { MessageType | "All" } = TableUtil.Assign({ "All" }, messageTypes)
OutputConsole.MessageTypes = messageTypes
OutputConsole.FilterTypes = filterTypes

-- * Helpers
local function eachMessageType(callback: (messageType: MessageType) -> ())
	for _, fType in ipairs(messageTypes) do
		callback(fType)
	end
end

function OutputConsole:_eachFilterStates(callback: (messageType: MessageType, state: State<boolean>) -> ())
	eachMessageType(function(messageType: MessageType)
		callback(messageType, self._filterStates[messageType])
	end)
end

-- * Constructor
function OutputConsole.new(): OutputConsole
	local self = setmetatable(
		{
			maxLog = MAX_LOGS,
			maxOutput = MAX_OUTPUT,
			colors = COLORS,

			_messageBuffer = OrderedCollections.Set.new(),
			_filterStates = {},
			_filterAllState = Iris.State(true),
			_fullFilterState = Iris.State(true),

			_showDate = Iris.State(true),
			_showStartTime = Iris.State(true),

			_janitor = Janitor.new(),
		} :: OutputConsoleData,
		OutputConsole
	) :: OutputConsole

	eachMessageType(function(messageType: string)
		self._filterStates[messageType] = Iris.State(true)
	end)

	self._janitor:Add(
		LoggerManager.MessageOut:Connect(function(message: string, level: MessageType)
			self:SendMessage(message, level)
		end),
		"Disconnect"
	)

	return self
end

-- * API
function OutputConsole:Test()
	task.spawn(function()
		local i = 0
		while true do
			eachMessageType(function(messageType: MessageType)
				i += 1
				self:SendMessage(`Test {messageType} {i}`, messageType)
				task.wait(1)
			end)
		end
	end)
end

-- Message Methods
function OutputConsole:Clear()
	self._messageBuffer:Clear()
end

function OutputConsole:SendMessage(message: string, messageType: MessageType?)
	if self._messageBuffer:Size() >= self.maxLog then
		self._messageBuffer:PopBack()
	end

	local context: MessageContext = {
		message = message,
		messageType = messageType or "Log",
		date = DateTime.now(),
	}

	self._messageBuffer:PushFront(context)
end

-- Render
function OutputConsole:Render()
	Iris.Window({ "Output Console" }, { isOpened = DevStates.ShowOutputConsole })
	do
		-- * Menu Bar
		Iris.SeparatorText({ "Tools" })
		Iris.SameLine()
		do
			-- * Clear button
			if Iris.Button({ "Clear" }).clicked() then
				self:Clear()
			end
			-- * Search
		end
		Iris.End()

		-- * Options Field
		Iris.SeparatorText({ "Options" })
		Iris.SameLine()
		do
			Iris.Checkbox({ "Show Date" }, { isChecked = self._showDate })
		end
		Iris.End()

		-- * Filters Field
		Iris.CollapsingHeader({ "Filters" })
		do
			Iris.Table({ 4 })
			do
				-- * Filters toggle
				local function toggleAll(active: boolean)
					self:_eachFilterStates(function(fType: MessageType, state: State<boolean>)
						state:set(active)
					end)
				end

				local function updateAllState()
					local allActive = true

					self:_eachFilterStates(function(fType: MessageType, state: State<boolean>)
						if not state:get() then
							allActive = false
						end
					end)

					if self._fullFilterState:get() ~= allActive then
						self._fullFilterState:set(allActive)
					end
				end

				-- * Filters "All"
				do
					local checkbox = Iris.Checkbox({ "All" }, { isChecked = self._filterAllState })
					local fullState = self._fullFilterState
					local allState = self._filterAllState

					if allState:changed() and checkbox:hovered() then
						toggleAll(allState:get())
					end

					if self._fullFilterState:changed() then
						allState:set(fullState:get())
					end
				end

				-- * Other filters
				local cnt = 0
				self:_eachFilterStates(function(fType: MessageType, state: State<boolean>)
					cnt += 1
					if cnt % 2 == 0 then
						Iris.NextColumn()
					end
					Iris.Checkbox({ fType }, { isChecked = state })
					if state:changed() then
						updateAllState()
					end
				end)
			end
			Iris.End()
		end
		Iris.End()

		-- * Output Field
		Iris.SeparatorText({ "Output" })
		Iris.Indent()
		do
			local outputs = 0
			self._messageBuffer:Each(function(context: MessageContext)
				if self._filterAllState:get() or self._filterStates[context.messageType]:get() then
					Iris.SameLine()
					do
						if self._showDate:get() then
							Iris.Text({
								`[{context.date:FormatLocalTime("HH:mm:ss.SSS", LocalizationService.RobloxLocaleId)}]:`,
							})
						end
						Iris.TextColored({ `{context.message}`, self.colors[context.messageType] })
					end
					Iris.End()

					outputs += 1
				end
				return outputs <= self.maxOutput
			end)
		end
		Iris.End()
	end
	Iris.End()
end

return OutputConsole.new()
</file>

